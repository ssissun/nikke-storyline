---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import Masthead from '../components/Masthead.astro';
import Intro from '../components/Intro.astro';
import Legend from '../components/Legend.astro';
import Notes from '../components/Notes.astro';
import Timeline from '../components/Timeline.astro';
import Bonus from '../components/Bonus.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = 'https://ssissun.github.io/nikke-storyline/';
const OG_IMAGE = `${SITE_URL}assets/og-thumbnail.jpg`;
const TITLE = 'NIKKE 스토리 감상 순서 가이드';
const DESCRIPTION =
  'NIKKE(니케) 스토리 감상 순서 가이드 — 메인 · 이벤트 · 사이드 · 호감도 스토리를 이야기 흐름 기준으로 정리한 타임라인.';
const LAST_UPDATED = '2026-05-14';
---

<BaseLayout
  title={TITLE}
  description={DESCRIPTION}
  ogImage={OG_IMAGE}
  pageUrl={SITE_URL}
>
  <ThemeSwitch />
  <div class="page">
    <Masthead lastUpdated={LAST_UPDATED} />
    <Intro />
    <Legend />
    <Notes />
    <Timeline />
    <Bonus />
    <Footer />
  </div>
</BaseLayout>
