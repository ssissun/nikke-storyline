---
import { bonusCards } from '../data/bonus';
---

<section class="notes bonus">
  <h2>메인 스토리 흐름과는 큰 관련이 없으나 — 스토리가 호평인 이벤트</h2>
  <p class="bonus-lead">
    메인 스토리 흐름과는 큰 관련이 없어 본편 이해에 영향은 적지만, 단독 감상으로 추천받는
    이벤트들.
  </p>
  <div class="notes-grid">
    {
      bonusCards.map((card) => (
        <div class="note">
          <span class="tag">{card.tag}</span>
          <div class="ttl">{card.title}</div>
          <div class="body">
            <ul class="bonus-list">
              {card.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
            {card.related && (
              <div class="rel-nikke">
                <span class="rl">관련 {card.related.type === 'squad' ? '스쿼드' : '니케'}</span>
                {card.related.value}
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>
