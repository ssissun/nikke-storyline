---
import { bonusCards } from '../data/bonus';
---

<section class="notes bonus">
  <h2>메인 줄기와는 무관하지만 — 스토리가 호평인 이벤트</h2>
  <p class="bonus-lead">
    스토리 라인에 포함되지 않아 본편 이해에 영향은 없지만, 단독 감상으로 추천받는
    이벤트들.
  </p>
  <div class="notes-grid">
    {
      bonusCards.map((card) => (
        <div class="note">
          <span class="tag">{card.tag}</span>
          <div class="ttl">{card.title}</div>
          <div class="body">
            <ul class="bonus-list">
              {card.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
            <div class="rel-nikke">
              <span class="rl">관련 니케</span> {card.relatedNikke}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
