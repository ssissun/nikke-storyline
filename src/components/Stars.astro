---
import type { Importance } from '../data/types';

interface Props {
  required: boolean;
  importance?: Importance;
}

const { required, importance } = Astro.props;

let filled = 3;
let dim = 0;
let label = '';

if (!required) {
  if (importance === 'high') {
    filled = 3;
    dim = 0;
    label = '높음';
  } else if (importance === 'medium') {
    filled = 2;
    dim = 1;
    label = '중간';
  } else if (importance === 'low') {
    filled = 1;
    dim = 2;
    label = '낮음';
  }
}

const filledStars = '★'.repeat(filled);
const dimStars = '☆'.repeat(dim);
---

<span class="imp">
  <span class="stars">{filledStars}</span>{dim > 0 && <span class="stars-dim">{dimStars}</span>}
  {label && <> {label}</>}
</span>
